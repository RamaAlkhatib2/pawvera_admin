rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── /users/{uid} and sub-collections ─────────────────────────
    match /users/{uid} {
      allow read, write: if true;
    }
    match /users/{uid}/{sub=**} {
      allow read, write: if true;
    }

    // ── /admins/{uid} ────────────────────────────────────────────
    match /admins/{uid} {
      allow read, write: if true;
    }

    // ── /service_shops/{id} and sub-collections ──────────────────
    match /service_shops/{id} {
      allow read, write: if true;
    }
    match /service_shops/{id}/{sub=**} {
      allow read, write: if true;
    }

    // ── /adoption_posts/{id} ─────────────────────────────────────
    match /adoption_posts/{id} {
      allow read, write: if true;
    }

    // ── /reminder_types/{id} ─────────────────────────────────────
    match /reminder_types/{id} {
      allow read, write: if true;
    }

    // ── /pet_types/{id} ──────────────────────────────────────────
    match /pet_types/{id} {
      allow read, write: if true;
    }

    // ── /bookings/{id} ───────────────────────────────────────────
    match /bookings/{id} {
      allow read, write: if true;
    }

    // ── /orders/{id} ─────────────────────────────────────────────
    match /orders/{id} {
      allow read, write: if true;
    }

    // ── /products/{id} ───────────────────────────────────────────
    match /products/{id} {
      allow read, write: if true;
    }

    // ── /reviews/{id} ────────────────────────────────────────────
    match /reviews/{id} {
      allow read, write: if true;
    }

    // ── /conversations/{id} and messages sub-collection ──────────
    match /conversations/{id} {
      allow read, write: if true;
    }
    match /conversations/{id}/messages/{msgId} {
      allow read, write: if true;
    }

    // ── /notifications/{id} ──────────────────────────────────────
    match /notifications/{id} {
      allow read, write: if true;
    }

    // ── /users_cart/{id} and sub-collections ─────────────────────
    match /users_cart/{id} {
      allow read, write: if true;
    }
    match /users_cart/{id}/{sub=**} {
      allow read, write: if true;
    }

    // ── collection group queries (e.g. collectionGroup('pets')) ──
    match /{path=**}/pets/{petId} {
      allow read, write: if true;
    }

    // ── deny everything else ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
